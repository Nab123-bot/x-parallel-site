// ─── Animated noise canvas background ───────────────────────────────────────
function NoiseCanvas() {
  const canvasRef = useRef(null);
  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    let animId;
    // Set canvas size initially and on resize
    const setCanvasSize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    };
    setCanvasSize();
    window.addEventListener("resize", setCanvasSize);

    const draw = () => {
      const imageData = ctx.createImageData(canvas.width, canvas.height);
      for (let i = 0; i < imageData.data.length; i += 4) {
        const v = Math.random() * 255 * 0.04;
        imageData.data[i] = v;
        imageData.data[i + 1] = v;
        imageData.data[i + 2] = v;
        imageData.data[i + 3] = 255;
      }
      ctx.putImageData(imageData, 0, 0);
      animId = requestAnimationFrame(draw);
    };
    draw();
    return () => {
      cancelAnimationFrame(animId);
      window.removeEventListener("resize", setCanvasSize);
    };
  }, []);
  return <canvas ref={canvasRef} className="fixed inset-0 pointer-events-none z-0 opacity-40" />;
}

// ─── SVG Logo ────────────────────────────────────────────────────────────────
function Logo({ size = 180 }) {
  return (
    <svg width={size} height={size * 0.55} viewBox="0 0 280 154" fill="none" xmlns="http://www.w3.org/2000/svg">
      <text x="8"  y="64"  fontFamily="'Barlow Condensed', 'Arial Narrow', sans-serif" fontWeight="900" fontSize="58" letterSpacing="3" fill="white">THE</text>
      <text x="134" y="64" fontFamily="'Barlow Condensed', 'Arial Narrow', sans-serif" fontWeight="900" fontSize="58" fill="#CC0000">X</text>
      <text x="8"  y="134" fontFamily="'Barlow Condensed', 'Arial Narrow', sans-serif" fontWeight="900" fontSize="58" letterSpacing="3" fill="white">PARA</text>
      <rect x="152" y="84" width="7"  height="54" fill="#CC0000" rx="1"/>
      <rect x="163" y="84" width="7"  height="54" fill="#CC0000" rx="1"/>
      <text x="175" y="134" fontFamily="'Barlow Condensed', 'Arial Narrow', sans-serif" fontWeight="900" fontSize="58" letterSpacing="3" fill="white">EL</text>
    </svg>
  );
}


// ─── Language switcher ────────────────────────────────────────────────────────
function LangSwitcher({ lang, setLang }: { lang: Lang; setLang: (l: Lang) => void }) {
  const langs: { code: Lang; label: string }[] = [
    { code: "fr", label: "FR" },
    { code: "en", label: "EN" },
    { code: "ar", label: "ع"  },
  ];
  return (
    <div className="flex items-center border border-white/10 overflow-hidden">
      {langs.map(({ code, label }, i) => (
        <button
          key={code}
          onClick={() => setLang(code)}
          className={[
            "px-3 py-1.5 text-[10px] font-black tracking-widest uppercase transition-all duration-200",
            i > 0 ? "border-l border-white/10" : "",
            lang === code
              ? "bg-red-600 text-white"
              : "text-white/30 hover:text-white hover:bg-white/5",
          ].join(" ")}
        >
          {label}
        </button>
      ))}
    </div>
  );
}


// ─── Glitch text ─────────────────────────────────────────────────────────────
function GlitchText({ text }) {
  return (
    <span className="relative inline-block glitch" data-text={text}>
      {text}
      <style>{`
        .glitch { position: relative; }
        .glitch::before,
        .glitch::after {
          content: attr(data-text);
          position: absolute;
          top: 0; left: 0;
          width: 100%; height: 100%;
          clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%);
        }
        .glitch::before {
          color: #CC0000;
          animation: glitch1 3.5s infinite steps(1);
          transform: translateX(-3px);
        }
        .glitch::after {
          color: white;
          animation: glitch2 3.5s infinite steps(1);
          transform: translateX(3px);
          clip-path: polygon(0 60%, 100% 60%, 100% 75%, 0 75%);
        }
        @keyframes glitch1 {
          0%,90%,100% { opacity: 0; transform: translateX(0); }
          91%          { opacity: 1; transform: translateX(-4px); }
          93%          { opacity: 0; }
          95%          { opacity: 1; transform: translateX(3px); }
          97%          { opacity: 0; }
        }
        @keyframes glitch2 {
          0%,90%,100% { opacity: 0; transform: translateX(0); }
          92%          { opacity: 1; transform: translateX(4px); }
          94%          { opacity: 0; }
          96%          { opacity: 1; transform: translateX(-2px); }
          98%          { opacity: 0; }
        }
      `}</style>
    </span>
  );
}

